# Mantle Network
MANTLE_RPC_URL=https://rpc.mantle.xyz
MANTLE_TESTNET_RPC_URL=https://rpc.sepolia.mantle.xyz
DEPLOYER_PRIVATE_KEY=           # wallet that deploys the contract
AGENT_PRIVATE_KEY=              # wallet that writes signals on-chain

# Telegram
TELEGRAM_BOT_TOKEN=             # obtained from @BotFather

# Deployed contract
CONTRACT_ADDRESS=               # filled in after deploy

# Agent configuration
SCAN_INTERVAL_SECONDS=30        # polling frequency
MIN_CONFIDENCE_THRESHOLD=70     # minimum confidence to emit a signal
WHALE_THRESHOLD_MNT=10000       # minimum MNT balance to track a wallet

# API (optional)
FASTAPI_PORT=8000
